<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Trokke Slips</title>
<style>
body{font-family:Arial;background:#f4f6f8;padding:16px}
.card{background:white;padding:14px;margin:10px 0;border-radius:12px}
input{padding:10px;font-size:16px}
button{padding:10px;background:#222;color:white;border:0;border-radius:8px}
.row{border-bottom:1px solid #ddd;padding:10px 0}
.small{font-size:13px;color:#555}
</style>
</head>
<body>
<a href="/">⬅ Home</a>
<h2>🚚 Trokke Slips</h2>

<div class="card">
<h3>Loaded trucks</h3>
<div id="slips">Loading...</div>
</div>

<div class="card">
<h3>Tonnes per field</h3>
<div id="fieldSummary"></div>
</div>

<div class="card">
<h3>Tonnes per week</h3>
<div id="weekSummary"></div>
</div>

<script>
async function load(){
  const res = await fetch('/api/trokke-slips');
  const d = await res.json();

  slips.innerHTML = d.slips.map(x=>`
    <div class="row">
      <b>${x.plate}</b> — ${x.originalWeight} t
      <div class="small">${x.date} | ${x.field} | Driver ${x.driver}</div>
      <label>
        <input type="checkbox" ${x.delivered?'checked':''}
          onchange="saveSlip(${x.rowNumber}, this.checked, document.getElementById('bw${x.rowNumber}').value)">
        Delivered
      </label>
      <input id="bw${x.rowNumber}" type="number" step="0.001" value="${x.buyerWeight || ''}" placeholder="Buyer weight"
        onchange="saveSlip(${x.rowNumber}, document.querySelector('[onchange*=\\'${x.rowNumber}\\']').checked, this.value)">
    </div>
  `).join('');

  fieldSummary.innerHTML = d.byField.map(x=>`<div><b>${x.name}</b>: ${x.total.toFixed(3)} t</div>`).join('');
  weekSummary.innerHTML = d.byWeek.map(x=>`<div><b>${x.name}</b>: ${x.total.toFixed(3)} t</div>`).join('');
}

async function saveSlip(rowNumber, delivered, buyerWeight){
  await fetch('/api/trokke-slips/update',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({rowNumber, delivered, buyerWeight})
  });
  load();
}

load();
</script>
</body>
</html>
