<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Cow Lookup</title>
<style>
body{
  font-family:Arial;
  max-width:900px;
  margin:auto;
  padding:20px;
}
input,button{
  padding:10px;
  font-size:16px;
}
.card{
  border:1px solid #ccc;
  border-radius:8px;
  padding:15px;
  margin-top:15px;
}
pre{
  white-space:pre-wrap;
}
</style>
</head>
<body>

<h2>🐄 Cow Lookup</h2>

<input id="cowId" placeholder="Enter cow number">
<button onclick="lookup()">Search</button>

<div id="result"></div>

<script>
async function lookup(){
  const cowId=document.getElementById('cowId').value.trim();

  if(!cowId){
    alert('Enter cow number');
    return;
  }

  const res=await fetch('/api/dashboard?cowId='+encodeURIComponent(cowId));
  const data=await res.json();

  const div=document.getElementById('result');

  div.innerHTML=`
    <div class="card">
      <h3>Cow ${data.cowId}</h3>
      <p><b>In Inventory:</b> ${data.inInventory ? 'YES' : 'NO'}</p>

      <h4>➕ Bees plus</h4>
      <pre>${JSON.stringify(data.beesPlus,null,2)}</pre>

      <h4>➖ Bees minus</h4>
      <pre>${JSON.stringify(data.beesMinus,null,2)}</pre>

      <h4>🐄 Kalf merk</h4>
      <pre>${JSON.stringify(data.kalfMerk,null,2)}</pre>

      <h4>📦 Inventory row</h4>
      <pre>${JSON.stringify(data.inventory,null,2)}</pre>
    </div>
  `;
}
</script>

</body>
</html>
